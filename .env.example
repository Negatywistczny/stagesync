# apps/server — HTTP listen (default 4000)
PORT=4000

# Absolute or relative path to data root (library + projects).
# Default (desktop / user host): ~/Documents/StageSync
# Default (Docker / Compose):    /app/data  (set explicitly in compose files)
# STAGESYNC_DATA_DIR=

# Set to 1 during local development to keep data under <repo>/data
# instead of ~/Documents/StageSync.
STAGESYNC_REPO_DEV=1

# Prod / Docker: Vite build directory served by the Node server.
# STAGESYNC_STATIC_DIR=/app/web

# Tauri thin shell (apps/desktop) — URL of local StageSync host.
# STAGESYNC_URL=http://127.0.0.1:4000/admin

# ── Production only (compose.prod.yml) ──────────────────────────────────────

# Image version to pull from GHCR (compose.prod.yml).
# STAGESYNC_VERSION=5.0.0-beta.1

# GHCR credentials for Watchtower image pull.
# Generate a GitHub PAT with read:packages scope.
# GHCR_USER=your-github-username
# GHCR_TOKEN=ghp_...

# Watchtower HTTP API token (shared between compose.prod.yml and apps/server).
# Generate a random secret: openssl rand -hex 32
# WATCHTOWER_TOKEN=

# GitHub API token for update-status (Docker/host). Private repo needs Contents read;
# public repos work without a token. Desktop sidecar skips this check (Tauri updater).
# Fine-grained PAT: Contents read-only on this repo.
# STAGESYNC_GITHUB_TOKEN=ghp_...
