{
  "name": "@stagesync/server",
  "version": "0.0.0",
  "private": true,
  "license": "BUSL-1.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "migrate:legacy": "tsx src/cli/migrate-legacy.ts"
  },
  "dependencies": {
    "@stagesync/shared": "workspace:*",
    "easymidi": "^3.2.0",
    "express": "^5.1.0",
    "multer": "^2.2.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@stagesync/eslint-config": "workspace:*",
    "@stagesync/typescript-config": "workspace:*",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.5",
    "tsx": "^4.20.3",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  }
}
