{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StageSync",
  "version": "5.0.0-alpha.13",
  "identifier": "com.stagesync.app",
  "build": {
    "frontendDist": "../ui-placeholder",
    "devUrl": "http://127.0.0.1:4000/admin",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "StageSync",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "url": "http://127.0.0.1:4000/admin"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "dmg",
      "msi"
    ],
    "externalBin": [
      "bin/stagesync-host"
    ],
    "resources": [
      "resources/sidecar/**/*",
      "lib/**/*",
      "share/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "wix": {
        "version": "5.0.0.13"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Negatywistczny/stagesync/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcyQUVGNjNEMkIyODZBRjgKUldUNGFpZ3JQZmF1Y3RVK1ZVYzl3SXFBU210SHhHbDRFSVNoSFUvVUJMQ0d6bytWeGdGZ1o0bE4K"
    }
  }
}
