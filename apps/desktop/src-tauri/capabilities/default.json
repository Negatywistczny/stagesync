{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default StageSync desktop capability (thin shell)",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "bin/stagesync-host",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "updater:default"
  ]
}
