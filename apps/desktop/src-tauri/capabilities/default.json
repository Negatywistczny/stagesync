{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default StageSync desktop capability (Launcher + local sidecar UI)",
  "windows": ["main"],
  "remote": {
    "urls": [
      "http://127.0.0.1:1420",
      "http://127.0.0.1:1420/*",
      "http://localhost:1420",
      "http://localhost:1420/*",
      "http://127.0.0.1:4000",
      "http://127.0.0.1:4000/*",
      "http://localhost:4000",
      "http://localhost:4000/*"
    ]
  },
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-set-fullscreen",
    "core:window:allow-is-fullscreen",
    "core:window:allow-set-simple-fullscreen",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "allow-toggle-window-fullscreen",
    "allow-open-external-url",
    "allow-nav-timeline-sync",
    "allow-nav-recent-sync",
    "allow-edit-history-sync",
    "allow-desktop-update",
    "allow-desktop-launcher",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "bin/stagesync-host",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "updater:default"
  ]
}
