{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "CI",
    "PORT",
    "STAGESYNC_DATA_DIR",
    "STAGESYNC_SEED_DIR",
    "STAGESYNC_REPO_DEV",
    "STAGESYNC_STATIC_DIR",
    "STAGESYNC_SHELL",
    "STAGESYNC_URL",
    "STAGESYNC_VERSION",
    "STAGESYNC_GITHUB_TOKEN",
    "STAGESYNC_UPDATER_URL",
    "STAGESYNC_UPDATER_TOKEN",
    "STAGESYNC_MIDI_INPUT",
    "STAGESYNC_MIDI_OUTPUT",
    "STAGESYNC_HOST_TOKEN",
    "STAGESYNC_ALLOW_REMOTE_LIFECYCLE",
    "STAGESYNC_BIND_HOST",
    "STAGESYNC_UPDATE_CHANNEL",
    "STAGESYNC_DISABLE_MDNS",
    "STAGESYNC_DISABLE_AUTO_UPDATE",
    "STAGESYNC_BACKUPS_DIR",
    "STAGESYNC_ASSETS_DIR",
    "LOG_LEVEL",
    "npm_package_version",
    "HOSTNAME",
    "HOME",
    "USERPROFILE",
    "pm_id",
    "PM2_HOME",
    "DEV",
    "NODE_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^build", "^check-types"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["coverage/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
